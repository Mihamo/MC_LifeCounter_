{
  "schemaVersion": 1,
  "id": "mc_lifecounter",
  "version": "${version}",
  "name": "MC Life Counter",
  "description": "A Minecraft mod that adds a lives system with hardcore mode progression",
  "authors": ["Mihamo"],
  "contact": {
    "homepage": "https://github.com/Mihamo/MC_LifeCounter_"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.mihamo.livescounter.MCLifeCounterMod"
    ]
  },
